# Dinner for Two — example Nginx reverse-proxy for a single DigitalOcean droplet.
#
# Why this file exists: the compose endpoint streams Server-Sent Events. The single
# thing that MUST be right is disabling proxy buffering on that route — otherwise
# Nginx holds the whole response until compose finishes and the UI looks frozen for
# ~5s with no streaming rationale. Everything else here is standard.
#
# Setup:
#   1. Run the app as ONE process (see deploy/DEPLOY.md — the in-memory spread/share
#      store is NOT shared across workers, so do not use PM2 cluster mode).
#         next build && next start -p 3000      (or: pm2 start "npm start" --name dft)
#   2. Copy this to /etc/nginx/sites-available/dinner-for-two, edit server_name,
#      symlink into sites-enabled, `nginx -t`, `systemctl reload nginx`.
#   3. TLS: `certbot --nginx -d your.domain` rewrites the :443 block below for you.

upstream dft_app {
    server 127.0.0.1:3000;
    keepalive 32;
}

# ---- HTTP: redirect to HTTPS (certbot will also manage this) ----
server {
    listen 80;
    listen [::]:80;
    server_name your.domain.com;
    location / {
        return 301 https://$host$request_uri;
    }
}

# ---- HTTPS ----
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name your.domain.com;

    # certbot fills these in (ssl_certificate / ssl_certificate_key).
    # ssl_certificate     /etc/letsencrypt/live/your.domain.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/your.domain.com/privkey.pem;

    # Reasonable upload/headers; the briefs are tiny.
    client_max_body_size 1m;

    # ---- SSE compose stream: the one route that needs buffering OFF ----
    # Matches /api/compose/<restaurantId>. Without proxy_buffering off the rationale
    # won't stream token-by-token. read_timeout covers the worst-case compose tail.
    location ~ ^/api/compose/ {
        proxy_pass http://dft_app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";          # keep-alive to upstream
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering off;                     # <-- the critical line for SSE
        proxy_cache off;
        proxy_read_timeout 120s;                 # a stalled compose won't hang forever
        chunked_transfer_encoding on;
        # The app also sends X-Accel-Buffering: no on this response as a belt-and-braces.
    }

    # ---- Everything else: normal buffered proxy ----
    location / {
        proxy_pass http://dft_app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
