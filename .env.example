# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# Anthropic — Haiku (brief parse) + Sonnet (composition)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (by MongoDB) — description embeddings for retrieval. Create at dash.voyageai.com
VOYAGE_API_KEY=pa-...

# Optional model + tuning overrides (defaults live in src/config.ts)
# PARSE_MODEL=claude-haiku-4-5-20251001
# COMPOSE_MODEL=claude-sonnet-4-6
# VOYAGE_MODEL=voyage-4-lite
# MMR_LAMBDA=0.7
# CANDIDATE_POOL=24
